<%- include("partials/header", { title: "Booking - Smart WhatsApp" }) %>
<%- include("partials/nav", { active: "booking" }) %>

<main class="container wide">
  <h1>Booking flow</h1>
  <p class="muted small">Cuando un lead reserva en GHL/Calendly, el bot rota entre tus 3 chips group-creators, crea grupo, mete al equipo como admin y dispara el flujo.</p>

  <!-- Sección Equipo -->
  <section style="margin-top:32px;">
    <div class="row-between">
      <h2 style="font-size:18px;">Equipo (van adentro del grupo)</h2>
      <button onclick="addMember()">+ Agregar miembro</button>
    </div>
    <p class="muted small">Tomi (owner), Carlos (closer), Triager — todos van como admin del grupo creado.</p>
    <div id="teamList" class="muted small">Cargando...</div>
  </section>

  <!-- Modo de operación -->
  <section style="margin-top:32px;">
    <h2 style="font-size:18px;">Modo de operación</h2>
    <div class="form-grid">
      <label class="full">
        <span>Cómo procesar bookings</span>
        <select id="cfg_mode" onchange="onModeChange()">
          <option value="full">Flow completo (crea grupo + manda DM con invite)</option>
          <option value="contact_only">Solo contacto + etiqueta (NO manda mensajes)</option>
        </select>
        <small class="muted">
          <strong>Contact only</strong>: el chip guarda al lead con su nombre real y le aplica la etiqueta del budget (las etiquetas tienen que estar creadas previamente en WhatsApp Business app del chip).
        </small>
      </label>
    </div>

    <div id="contact_only_block" style="margin-top:14px; display:none;">
      <h3 style="font-size:15px;">Mapeo de etiquetas por budget rank</h3>
      <p class="muted small">Cuando llega un lead con budget_rank N, se le aplica la etiqueta con el nombre que pongas acá. La etiqueta DEBE existir en la app WhatsApp Business del chip.</p>
      <p class="muted small">📌 <strong>Etiqueta de hora automática</strong>: además del budget, se aplica la etiqueta de la hora según <code>scheduled_at</code> del webhook. Convención: 10-12 → "10 AM"/"11 AM"/"12 AM"; 13-21 → "13 PM"/.../"21 PM". Si la hora cae fuera de ese rango, no se aplica etiqueta.</p>
      <div class="form-grid">
        <label>
          <span>Rank 1 → etiqueta</span>
          <input id="lbl_1" placeholder="500 a 990" />
        </label>
        <label>
          <span>Rank 2 → etiqueta</span>
          <input id="lbl_2" placeholder="1.000 a 2.000" />
        </label>
        <label>
          <span>Rank 3 → etiqueta</span>
          <input id="lbl_3" placeholder="2.000 a 3.000" />
        </label>
        <label>
          <span>Rank 4 → etiqueta (opcional)</span>
          <input id="lbl_4" placeholder="" />
        </label>
      </div>
      <div style="margin-top:10px;display:flex;gap:8px;align-items:center;">
        <button onclick="checkLabels()">Verificar etiquetas existentes</button>
        <span id="labelsStatus" class="muted small"></span>
      </div>
    </div>
  </section>

  <!-- Sección Canal del DM -->
  <section style="margin-top:32px;" id="block_full_flow">
    <h2 style="font-size:18px;">Canal del DM al lead</h2>
    <div class="form-grid">
      <label class="full">
        <span>Cómo se le manda el mensaje con el invite</span>
        <select id="cfg_dm_channel" onchange="onChannelChange()">
          <option value="callbell">Callbell API (lead vive en Callbell)</option>
          <option value="evolution">Evolution admin chip (lead viene chateando con uno de los chips de Smart WhatsApp)</option>
        </select>
        <small class="muted">Callbell mantiene la continuidad del thread del lead — es el setup correcto si tus leads entran via Callbell.</small>
      </label>
      <label class="full" id="row_callbell" style="display:none;">
        <span>Callbell channel UUID (el número que envía)</span>
        <input id="cfg_callbell_uuid" placeholder="ej: 7d04d58a-9762-4759-89b6-486a26bb47f8" />
        <small class="muted">UUID del channel en Callbell que va a mandar el mensaje. <code>CALLBELL_API_KEY</code> se setea como env var en Railway.</small>
      </label>
      <label class="full" id="row_admin" style="display:none;">
        <span>Admin chip Evolution (si elegís Evolution)</span>
        <select id="cfg_instance"></select>
        <small class="muted">Chip de Smart WhatsApp que manda el DM. NO crea grupos.</small>
      </label>
    </div>
  </section>

  <!-- Sección Chips -->
  <section style="margin-top:32px;">
    <h2 style="font-size:18px;">Chips para crear grupos</h2>
    <div class="form-grid">
      <label class="full">
        <span>Chips group-creators (rotación round-robin, menos cargado del día primero)</span>
        <div id="cfg_creators_box" class="checkbox-list"></div>
        <small class="muted">Marcá los 2-3 chips que SOLO crean grupos. Independiente del canal del DM.</small>
      </label>
      <label class="full">
        <span>Team members que se agregan al grupo</span>
        <div id="cfg_team_box" class="checkbox-list"></div>
        <small class="muted">Tildá quiénes entran a cada grupo creado (van como admin si está activado).</small>
      </label>
    </div>
  </section>

  <!-- Sección Config -->
  <section style="margin-top:32px;">
    <h2 style="font-size:18px;">Templates y timing</h2>
    <div class="form-grid">
      <label>
        <span>Esperar antes del DM (minutos)</span>
        <input id="cfg_delay_dm" type="number" min="0" value="10" />
      </label>
      <label>
        <span>Esperar tras entrar al grupo (segundos)</span>
        <input id="cfg_delay_post" type="number" min="0" value="60" />
      </label>
      <label class="full">
        <span>Nombre del grupo (plantilla)</span>
        <input id="cfg_group_name" placeholder="{date} - {time} - {lead_name} - ({budget_rank})" />
        <small class="muted">Variables: {date} {time} {datetime} {lead_name} {budget_rank}. Ej: <code>15/04 - 13:00 - Juan Carlos - (1)</code></small>
      </label>
      <label class="full">
        <span>Nombre con el que se guarda el contacto (libreta del admin chip)</span>
        <input id="cfg_contact_name" placeholder="{lead_name}" />
        <small class="muted">Cuando el booking se procesa, el chip de Tomi guarda al lead con este nombre — fácil de buscar en WhatsApp. Variables disponibles: {lead_name} {date} {time} {budget_rank}. Ej: <code>{lead_name} ({budget_rank})</code> → "Juan Carlos (1)"</small>
      </label>
      <label class="full">
        <span>Mensaje DM al lead (con invite link)</span>
        <textarea id="cfg_dm" rows="5"></textarea>
        <small class="muted">Variables: {date} {time} {invite_url} {lead_name} {budget_rank}.</small>
      </label>
      <label class="full">
        <span>Mensaje de bienvenida en el grupo (al entrar el lead)</span>
        <textarea id="cfg_post" rows="3"></textarea>
        <small class="muted">Variables: {lead_name} {date} {time} {budget_rank}.</small>
      </label>
      <label class="full">
        <span>URL del audio de bienvenida (opcional)</span>
        <input id="cfg_audio" placeholder="https://..." />
        <small class="muted">Audio que se manda en el grupo. URL pública (.mp3 / .ogg / .m4a).</small>
      </label>
      <label class="checkbox">
        <input id="cfg_promote" type="checkbox" checked /> Promover team a admin en el grupo
      </label>
      <label class="checkbox">
        <input id="cfg_enabled" type="checkbox" checked /> Booking flow activado
      </label>
    </div>
    <div style="margin-top:16px;display:flex;gap:10px;flex-wrap:wrap;">
      <button class="primary" onclick="saveCfg()">Guardar config</button>
      <button onclick="testFire()">▶ Test (simular booking)</button>
    </div>
    <p id="cfgMsg" class="err" style="margin-top:8px;"></p>
  </section>

  <!-- Webhook URL -->
  <section style="margin-top:32px;">
    <h2 style="font-size:18px;">Webhook URL para GHL / Calendly</h2>
    <p class="muted small">Pegá en GHL. POST con JSON: <code>{ phone, name, scheduled_at, budget_rank }</code> (budget_rank: 1-4).</p>
    <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
      <code id="webhookUrl" style="background:#0e0e10;padding:10px 14px;border-radius:6px;font-size:13px;flex:1;word-break:break-all;">Cargando...</code>
      <button onclick="copyWebhook()">📋 Copiar</button>
      <button class="danger" onclick="regenToken()">🔄 Regenerar token</button>
    </div>
  </section>

  <!-- Historial -->
  <section style="margin-top:32px;">
    <h2 style="font-size:18px;">Últimos bookings</h2>
    <div id="eventsList" class="muted small">Cargando...</div>
  </section>
</main>

<style>
.container.wide { max-width: 1100px; }
.form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px 18px; margin-top: 16px; }
.form-grid label { display: flex; flex-direction: column; gap: 4px; font-size: 13px; color: #aaa; }
.form-grid input, .form-grid select, .form-grid textarea {
  background: #0e0e10; border: 1px solid #2a2a30; color: #fff;
  padding: 9px 11px; border-radius: 6px; font-size: 14px; font-family: inherit;
}
.form-grid textarea { resize: vertical; min-height: 80px; }
.form-grid label.full { grid-column: 1 / -1; }
.form-grid label.checkbox { flex-direction: row; align-items: center; gap: 8px; }
.form-grid label.checkbox input { width: 16px; height: 16px; }

.checkbox-list {
  display: flex; flex-wrap: wrap; gap: 8px;
  background: #0e0e10; border: 1px solid #2a2a30; border-radius: 6px; padding: 10px;
}
.checkbox-pill {
  display: flex; align-items: center; gap: 6px;
  background: #1a1a22; padding: 6px 10px; border-radius: 999px; font-size: 12px;
  border: 1px solid #2a2a30; cursor: pointer; user-select: none;
}
.checkbox-pill:hover { background: #22222c; }
.checkbox-pill input { margin: 0; width: 14px; height: 14px; }
.checkbox-pill.on { background: #2e2052; border-color: #6c5ce7; color: #fff; }

.member-row {
  display:grid; grid-template-columns: 1fr 180px 110px 70px auto auto; gap: 10px;
  align-items: center; padding: 10px; background: #15151a; border: 1px solid #2a2a30;
  border-radius: 6px; margin-top: 8px;
}
.member-row input, .member-row select {
  background: #0e0e10; border: 1px solid #2a2a30; color: #fff;
  padding: 7px 9px; border-radius: 5px; font-size: 13px;
}
.member-row button { padding: 5px 10px; font-size: 12px; }
.role-badge { padding: 2px 8px; border-radius: 999px; font-size: 10px; text-transform: uppercase; font-weight: 600; }
.role-badge.owner { background: #4e1313; color: #ff9090; }
.role-badge.closer { background: #134e26; color: #6dd66d; }
.role-badge.triager { background: #1a3a4e; color: #70c0ff; }
.role-badge.other { background: #2a2a30; color: #aaa; }

.event-row {
  padding: 10px 12px; background: #15151a; border: 1px solid #2a2a30;
  border-radius: 6px; margin-top: 8px; font-size: 13px;
  display: grid; grid-template-columns: 90px 1fr 120px 110px; gap: 12px; align-items: center;
}
.event-status { font-size:11px; font-weight:600; padding:3px 8px; border-radius:999px; text-transform:uppercase; }
.event-status.pending, .event-status.creating_group { background:#4e3613; color:#ffc870; }
.event-status.dm_sent { background:#1a3a4e; color:#70c0ff; }
.event-status.joined, .event-status.sending_welcome { background:#1a4e3a; color:#70ffc0; }
.event-status.completed { background:#134e26; color:#6dd66d; }
.event-status.failed { background:#4e1313; color:#ff7070; }
.rank-tag { background:#2e2052; color:#fff; padding:2px 7px; border-radius:6px; font-size:11px; }
</style>

<script>
let cfg = null;
let instances = [];
let teamMembers = [];

function esc(s){ return String(s||"").replace(/[<>&"']/g, c => ({"<":"&lt;",">":"&gt;","&":"&amp;",'"':"&quot;","'":"&#39;"})[c]); }

async function loadAll() {
  const r = await fetch("/api/booking-config").then(r => r.json());
  cfg = r;
  instances = r._instances || [];
  teamMembers = r._closers || [];
  renderAdminSelect();
  renderCreatorsCheckboxes(cfg.group_creator_instance_ids || []);
  renderTeamCheckboxes(cfg.team_member_ids || []);
  renderTeamList();
  document.getElementById("cfg_dm_channel").value = r.dm_channel || "callbell";
  document.getElementById("cfg_callbell_uuid").value = r.callbell_channel_uuid || "";
  document.getElementById("cfg_mode").value = r.contact_only_mode ? "contact_only" : "full";
  const lm = r.label_mapping || {};
  document.getElementById("lbl_1").value = lm["1"] || "";
  document.getElementById("lbl_2").value = lm["2"] || "";
  document.getElementById("lbl_3").value = lm["3"] || "";
  document.getElementById("lbl_4").value = lm["4"] || "";
  onChannelChange();
  onModeChange();
  document.getElementById("cfg_delay_dm").value = r.delay_before_dm_minutes ?? 10;
  document.getElementById("cfg_delay_post").value = r.post_join_delay_seconds ?? 60;
  document.getElementById("cfg_group_name").value = r.group_name_template || "{date} - {time} - {lead_name} - ({budget_rank})";
  document.getElementById("cfg_contact_name").value = r.contact_name_template || "{lead_name}";
  document.getElementById("cfg_dm").value = r.dm_text || "";
  document.getElementById("cfg_post").value = r.post_join_text || "";
  document.getElementById("cfg_audio").value = r.post_join_audio_url || "";
  document.getElementById("cfg_promote").checked = r.promote_team_to_admin !== false;
  document.getElementById("cfg_enabled").checked = r.enabled !== false;
  setTimeout(() => {
    document.getElementById("cfg_instance").value = r.instance_id || "";
  }, 30);
  const url = `${location.origin}/api/hooks/booking/${r.webhook_token}`;
  document.getElementById("webhookUrl").textContent = url;
  loadEvents();
}

function renderAdminSelect() {
  const sel = document.getElementById("cfg_instance");
  sel.innerHTML = '<option value="">— elegí el admin chip —</option>' +
    instances.map(i => `<option value="${i.id}">${esc(i.name)} (${i.status})</option>`).join("");
}

function renderCreatorsCheckboxes(selectedIds) {
  const box = document.getElementById("cfg_creators_box");
  if (!instances.length) { box.innerHTML = '<span class="muted">No tenés chips conectados todavía.</span>'; return; }
  box.innerHTML = instances.map(i => {
    const on = selectedIds.includes(i.id);
    return `<label class="checkbox-pill ${on ? "on" : ""}">
      <input type="checkbox" value="${i.id}" ${on ? "checked" : ""} onchange="this.parentElement.classList.toggle('on', this.checked)" />
      ${esc(i.name)} <span style="color:#888;">(${i.status})</span>
    </label>`;
  }).join("");
}

function renderTeamCheckboxes(selectedIds) {
  const box = document.getElementById("cfg_team_box");
  const active = teamMembers.filter(t => t.active);
  if (!active.length) { box.innerHTML = '<span class="muted">No tenés team members. Agregá arriba.</span>'; return; }
  box.innerHTML = active.map(t => {
    const on = selectedIds.includes(t.id);
    return `<label class="checkbox-pill ${on ? "on" : ""}">
      <input type="checkbox" value="${t.id}" ${on ? "checked" : ""} onchange="this.parentElement.classList.toggle('on', this.checked)" />
      ${esc(t.name)} <span class="role-badge ${t.role}" style="margin-left:4px;">${t.role}</span>
    </label>`;
  }).join("");
}

function renderTeamList() {
  const list = document.getElementById("teamList");
  if (!teamMembers.length) { list.textContent = "Sin team members. Agregá al menos a Tomi (owner), Carlos (closer) y el triager."; return; }
  list.innerHTML = teamMembers.map(t => `
    <div class="member-row" data-id="${t.id}">
      <input value="${esc(t.name)}" data-k="name" />
      <input value="${esc(t.phone)}" data-k="phone" placeholder="5491127167024" />
      <select data-k="role">
        ${["owner","closer","triager","other"].map(r => `<option value="${r}" ${t.role===r?"selected":""}>${r}</option>`).join("")}
      </select>
      <label style="color:#888;font-size:12px;text-align:center;">
        <input type="checkbox" data-k="active" ${t.active ? "checked" : ""} /> Activo
      </label>
      <button onclick="saveMember(${t.id})">💾</button>
      <button class="danger" onclick="delMember(${t.id})">🗑</button>
    </div>
  `).join("");
}

async function addMember() {
  const name = prompt("Nombre (ej: Tomi, Carlos, etc):");
  if (!name) return;
  const phone = prompt("Teléfono con código país, sin +. Ej: 5491127167024");
  if (!phone) return;
  const role = prompt("Rol: owner / closer / triager / other", "closer");
  if (!role) return;
  const r = await fetch("/api/closers", {
    method: "POST", headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ name, phone, role })
  });
  if (!r.ok) { alert((await r.json()).error); return; }
  loadAll();
}

async function saveMember(id) {
  const row = document.querySelector(`.member-row[data-id="${id}"]`);
  const body = {
    name: row.querySelector('[data-k="name"]').value.trim(),
    phone: row.querySelector('[data-k="phone"]').value.trim(),
    role: row.querySelector('[data-k="role"]').value,
    active: row.querySelector('[data-k="active"]').checked,
  };
  const r = await fetch(`/api/closers/${id}`, {
    method: "PUT", headers: { "Content-Type": "application/json" },
    body: JSON.stringify(body)
  });
  if (!r.ok) { alert((await r.json()).error); return; }
  loadAll();
}

async function delMember(id) {
  if (!confirm("¿Eliminar?")) return;
  await fetch(`/api/closers/${id}`, { method: "DELETE" });
  loadAll();
}

function collectChecked(boxId) {
  return Array.from(document.querySelectorAll(`#${boxId} input[type=checkbox]:checked`))
    .map(c => parseInt(c.value, 10));
}

function onChannelChange() {
  const ch = document.getElementById("cfg_dm_channel").value;
  document.getElementById("row_callbell").style.display = ch === "callbell" ? "flex" : "none";
  document.getElementById("row_admin").style.display = ch === "evolution" ? "flex" : "none";
}

function onModeChange() {
  const mode = document.getElementById("cfg_mode").value;
  document.getElementById("contact_only_block").style.display = mode === "contact_only" ? "block" : "none";
  document.getElementById("block_full_flow").style.display = mode === "contact_only" ? "none" : "block";
}

async function checkLabels() {
  const status = document.getElementById("labelsStatus");
  status.textContent = "Buscando...";
  const r = await fetch("/api/booking-config/labels").then(r => r.json());
  if (r.error) { status.textContent = "⚠ " + r.error; return; }
  if (!r.labels.length) { status.textContent = "El chip no tiene etiquetas. Creá primero en WA Business app."; return; }
  const names = r.labels.map(l => `"${l.name || l.label || l.id}"`).join(", ");
  status.textContent = `${r.labels.length} etiquetas: ${names}`;
}

async function saveCfg() {
  const msg = document.getElementById("cfgMsg");
  msg.style.color = "#ff7070";
  msg.textContent = "";
  const body = {
    instance_id: document.getElementById("cfg_instance").value || null,
    group_creator_instance_ids: collectChecked("cfg_creators_box"),
    team_member_ids: collectChecked("cfg_team_box"),
    dm_channel: document.getElementById("cfg_dm_channel").value,
    callbell_channel_uuid: document.getElementById("cfg_callbell_uuid").value.trim() || null,
    contact_only_mode: document.getElementById("cfg_mode").value === "contact_only",
    label_mapping: {
      "1": document.getElementById("lbl_1").value.trim(),
      "2": document.getElementById("lbl_2").value.trim(),
      "3": document.getElementById("lbl_3").value.trim(),
      "4": document.getElementById("lbl_4").value.trim(),
    },
    delay_before_dm_minutes: parseInt(document.getElementById("cfg_delay_dm").value || "10", 10),
    post_join_delay_seconds: parseInt(document.getElementById("cfg_delay_post").value || "60", 10),
    group_name_template: document.getElementById("cfg_group_name").value,
    contact_name_template: document.getElementById("cfg_contact_name").value,
    dm_text: document.getElementById("cfg_dm").value,
    post_join_text: document.getElementById("cfg_post").value,
    post_join_audio_url: document.getElementById("cfg_audio").value || null,
    promote_team_to_admin: document.getElementById("cfg_promote").checked,
    enabled: document.getElementById("cfg_enabled").checked,
  };
  const r = await fetch("/api/booking-config", {
    method: "PUT", headers: { "Content-Type": "application/json" },
    body: JSON.stringify(body)
  });
  if (!r.ok) { msg.textContent = (await r.json()).error || "Error al guardar"; return; }
  msg.style.color = "#6dd66d";
  msg.textContent = "✓ Guardado";
  setTimeout(() => msg.textContent = "", 2500);
}

function copyWebhook() {
  navigator.clipboard.writeText(document.getElementById("webhookUrl").textContent)
    .then(() => alert("Copiado!"));
}

async function regenToken() {
  if (!confirm("¿Generar token nuevo? El viejo deja de funcionar.")) return;
  await fetch("/api/booking-config/regenerate-token", { method: "POST" });
  loadAll();
}

async function testFire() {
  const phone = prompt("Tu número (con código país, sin +). Ej: 5491136109797");
  if (!phone) return;
  const name = prompt("Nombre del lead de prueba:", "Test Lead");
  const rank = prompt("Budget rank (1-4):", "1");
  // Hora para etiqueta de hora — default 13 PM (test razonable)
  const hour = prompt("Hora de la agenda (10-21, para la etiqueta de hora):", "13");
  let scheduled_at = null;
  const h = parseInt(hour || "0", 10);
  if (h >= 0 && h <= 23) {
    const d = new Date();
    d.setHours(h, 0, 0, 0);
    scheduled_at = d.toISOString();
  }
  const r = await fetch("/api/booking-config/test-fire", {
    method: "POST", headers: { "Content-Type": "application/json" },
    body: JSON.stringify({
      phone, name,
      budget_rank: parseInt(rank || "0", 10) || null,
      scheduled_at,
    })
  });
  const j = await r.json();
  if (!r.ok) { alert("Error: " + j.error); return; }
  // Show detailed result
  const lines = [];
  lines.push(`OK booking creado.`);
  if (j.mode === "contact_only") {
    lines.push(`Modo: solo contacto + etiqueta`);
    lines.push(`Contacto guardado: ${j.contact_saved ? "sí" : "NO " + (j.contact_save_error||"")}`);
    if (j.label_applied) lines.push(`✓ Etiqueta budget: "${j.label_applied}"`);
    if (j.label_error) lines.push(`⚠ Budget: ${j.label_error}`);
    if (j.hour_label_applied) lines.push(`✓ Etiqueta hora: "${j.hour_label_applied}"`);
    if (j.hour_label_error) lines.push(`⚠ Hora: ${j.hour_label_error}`);
  } else {
    lines.push(`En ${j.dm_in_minutes} min recibís el DM.`);
  }
  alert(lines.join("\n"));
  loadEvents();
}

async function loadEvents() {
  const rows = await fetch("/api/booking-config/events").then(r => r.json());
  const list = document.getElementById("eventsList");
  if (!rows.length) { list.textContent = "Sin bookings todavía."; return; }
  list.innerHTML = rows.map(r => `
    <div class="event-row">
      <span class="event-status ${r.status}">${r.status}</span>
      <div>
        <div><strong>${esc(r.lead_name || r.lead_phone)}</strong>
          ${r.budget_rank ? ` <span class="rank-tag">(${r.budget_rank})</span>` : ""}
          · ${esc(r.lead_phone)}</div>
        <div style="color:#888;font-size:11px;">
          ${r.scheduled_at ? "Call: " + new Date(r.scheduled_at).toLocaleString("es-AR") : ""}
          ${r.instance_name ? " · Creator: " + esc(r.instance_name) : ""}
          ${r.error_message ? " · ⚠ " + esc(r.error_message).slice(0, 80) : ""}
        </div>
      </div>
      <span style="color:#888;font-size:11px;">${new Date(r.created_at).toLocaleString("es-AR")}</span>
      <span>
        ${r.invite_url ? `<a href="${esc(r.invite_url)}" target="_blank">grupo ↗</a> · ` : ""}
        <a href="/api/booking-config/events/${r.id}/trace" target="_blank">trace</a>
      </span>
    </div>
  `).join("");
}

loadAll();
setInterval(loadEvents, 10000);
</script>

</body></html>
