# ─── App ────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
JWT_SECRET=change-this-to-random-string

# ─── Database (Railway Postgres) ────────────────────────
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ─── Evolution API (Railway service) ────────────────────
EVOLUTION_API_URL=https://evolution-api-production-fb1d.up.railway.app
EVOLUTION_API_KEY=9579ff7b5969ef3e888dc5b9c0c7db97640527c82a489bfbaef2cbcd7bcc66ed

# Webhook que Evolution llama cuando recibe msj/eventos
# En prod: https://tu-app.up.railway.app/api/webhook/evolution
WEBHOOK_BASE_URL=http://localhost:3000

# ─── Defaults de envío (overrideables por campaña) ──────
DEFAULT_DAILY_LIMIT_PER_CHIP=50
DEFAULT_HOURS_START=10
DEFAULT_HOURS_END=19
DEFAULT_DELAY_MIN_SEC=300
DEFAULT_DELAY_MAX_SEC=720
DEFAULT_BATCH_SIZE=10
DEFAULT_BATCH_PAUSE_MIN_SEC=1800
DEFAULT_BATCH_PAUSE_MAX_SEC=3600

# ─── Límites del sistema ────────────────────────────────
MAX_CHIPS_PER_USER=5
